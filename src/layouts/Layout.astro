---
import '/src/styles/global.css';

export interface Props {
  title?: string;
  description?: string;
}

const { title = 'Mathews Shaji | Backend-Leaning Full-Stack Developer', description = 'Portfolio of Mathews Shaji, backend-leaning full-stack developer — FastAPI, Go/Gin, Next.js, multi-tenant AWS/GCP/Azure.' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Mathews Shaji" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90' fill='%23c9a96e'>M</text></svg>" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garant:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400&family=JetBrains+Mono:wght@300;400;500;700&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="noise-overlay"></div>
    <div id="custom-cursor"></div>
    <canvas id="ambient-canvas"></canvas>
    <div class="cursor-glow" id="cursor-glow"></div>

    <slot />

    <script>
      import '/src/scripts/main.js';
    </script>
  </body>
</html>
