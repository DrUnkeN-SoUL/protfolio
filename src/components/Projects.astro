---
---

<section id="projects">
  <div class="container">
    <div class="section-header reveal">
      <div class="section-title-wrapper">
        <span class="section-diag">// 02 — Selected Work</span>
        <h2 class="section-title">Featured <em>Builds</em></h2>
        <div class="section-title-line"></div>
      </div>
      <p class="section-subtitle">A curated selection covering cloud cost governance, systems replication, sign language, and AI automation.</p>
    </div>

    <div class="portfolio-filters reveal">
      <button class="filter-btn active" data-filter="all">All</button>
      <button class="filter-btn" data-filter="multi-cloud">Multi-Cloud</button>
      <button class="filter-btn" data-filter="saas">SaaS &amp; Full-Stack</button>
      <button class="filter-btn" data-filter="systems">Go &amp; Systems</button>
      <button class="filter-btn" data-filter="ai-automation">AI &amp; Automation</button>
    </div>

    <div class="projects-grid" id="projects-grid">
      <div class="project-card glass-card" data-category="multi-cloud saas">
        <button class="project-toggle" aria-expanded="false" aria-controls="pc-body-1">
          <div class="project-card-header">
            <div class="project-icon"><i class="fa-solid fa-cloud-arrow-up"></i></div>
            <div class="project-toggle-right">
              <div class="project-links" onclick="event.stopPropagation()">
                <a href="https://github.com/DrUnkeN-SoUL" target="_blank" rel="noopener" aria-label="GitHub"><i class="fa-brands fa-github"></i></a>
              </div>
              <svg class="project-chevron" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/></svg>
            </div>
          </div>
          <div class="project-card-title-row">
            <span class="project-client">Enterprise Cost SaaS</span>
            <h3 class="project-title">CloudPositive Cost Governance</h3>
            <div class="project-preview-tech">FastAPI · React · SQS · OpenAI</div>
          </div>
        </button>
        <div class="project-card-collapsible" id="pc-body-1">
          <div class="project-card-body">
            <p class="project-desc">Multi-tenant SaaS for cost monitoring across AWS, GCP, and Azure. Per-tenant schema segregation, 20+ cost pipelines via SQS, secretless multi-cloud onboarding, and structured AI cost-estimation using GPT-4o-mini.</p>
          </div>
          <div class="project-card-footer">
            <span class="project-tag">FastAPI</span><span class="project-tag">React 18</span>
            <span class="project-tag">SQS</span><span class="project-tag">OpenSearch</span>
            <span class="project-tag">Terraform</span><span class="project-tag">OpenAI</span>
          </div>
        </div>
      </div>

      <div class="project-card glass-card" data-category="saas systems">
        <button class="project-toggle" aria-expanded="false" aria-controls="pc-body-2">
          <div class="project-card-header">
            <div class="project-icon"><i class="fa-solid fa-arrows-spin"></i></div>
            <div class="project-toggle-right">
              <div class="project-links" onclick="event.stopPropagation()">
                <a href="https://github.com/DrUnkeN-SoUL" target="_blank" rel="noopener" aria-label="GitHub"><i class="fa-brands fa-github"></i></a>
              </div>
              <svg class="project-chevron" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/></svg>
            </div>
          </div>
          <div class="project-card-title-row">
            <span class="project-client">Live Cloud Migration</span>
            <h3 class="project-title">Xmigrate eBPF Replicator</h3>
            <div class="project-preview-tech">Go · eBPF · Next.js · WebSocket</div>
          </div>
        </button>
        <div class="project-card-collapsible" id="pc-body-2">
          <div class="project-card-body">
            <p class="project-desc">Live block-level VM disk replication tool using eBPF to detect source changes. Multi-channel WebSocket Go dispatcher, lightweight C-shared migration plugins (AWS/Azure/GCP), and a Next.js 14 topology dashboard.</p>
          </div>
          <div class="project-card-footer">
            <span class="project-tag">Go</span><span class="project-tag">eBPF</span>
            <span class="project-tag">Next.js 14</span><span class="project-tag">Keycloak</span>
            <span class="project-tag">WebSocket</span><span class="project-tag">Framer Motion</span>
          </div>
        </div>
      </div>

      <div class="project-card glass-card" data-category="saas">
        <button class="project-toggle" aria-expanded="false" aria-controls="pc-body-3">
          <div class="project-card-header">
            <div class="project-icon"><i class="fa-solid fa-boxes-stacked"></i></div>
            <div class="project-toggle-right">
              <div class="project-links" onclick="event.stopPropagation()">
                <a href="https://github.com/DrUnkeN-SoUL" target="_blank" rel="noopener" aria-label="GitHub"><i class="fa-brands fa-github"></i></a>
              </div>
              <svg class="project-chevron" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/></svg>
            </div>
          </div>
          <div class="project-card-title-row">
            <span class="project-client">Exotic Green Austria</span>
            <h3 class="project-title">WMS &amp; Auto-Compliance</h3>
            <div class="project-preview-tech">FastAPI · Next.js 16 · Redis · Docker</div>
          </div>
        </button>
        <div class="project-card-collapsible" id="pc-body-3">
          <div class="project-card-body">
            <p class="project-desc">Full warehouse inventory tracker with batch tracking, compliance reports, webcam barcode scanner, and an automated timezone-aware compliance cron logger. Next.js 16 with Vitest, Playwright, and Web Vitals.</p>
          </div>
          <div class="project-card-footer">
            <span class="project-tag">FastAPI</span><span class="project-tag">Next.js 16</span>
            <span class="project-tag">Redis</span><span class="project-tag">PostgreSQL</span>
            <span class="project-tag">Zxing</span><span class="project-tag">Vitest</span>
          </div>
        </div>
      </div>

      <div class="project-card glass-card" data-category="saas">
        <button class="project-toggle" aria-expanded="false" aria-controls="pc-body-4">
          <div class="project-card-header">
            <div class="project-icon"><i class="fa-solid fa-hands-asl-interpreting"></i></div>
            <div class="project-toggle-right">
              <div class="project-links" onclick="event.stopPropagation()">
                <a href="https://github.com/DrUnkeN-SoUL" target="_blank" rel="noopener" aria-label="GitHub"><i class="fa-brands fa-github"></i></a>
              </div>
              <svg class="project-chevron" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/></svg>
            </div>
          </div>
          <div class="project-card-title-row">
            <span class="project-client">Dubai Govt. CDA</span>
            <h3 class="project-title">Sign Language Platform</h3>
            <div class="project-preview-tech">Next.js 15 · Azure · PostgreSQL</div>
          </div>
        </button>
        <div class="project-card-collapsible" id="pc-body-4">
          <div class="project-card-body">
            <p class="project-desc">Official government multilingual event &amp; quiz management system supporting the Guinness World Record Emirati Sign Language initiative. Passwordless magic-link auth, English/Arabic RTL, reCAPTCHA, soft-delete logs.</p>
          </div>
          <div class="project-card-footer">
            <span class="project-tag">Next.js 15</span><span class="project-tag">PostgreSQL</span>
            <span class="project-tag">i18n</span><span class="project-tag">SendGrid</span>
            <span class="project-tag">Azure</span><span class="project-tag">Docker</span>
          </div>
        </div>
      </div>

      <div class="project-card glass-card" data-category="ai-automation">
        <button class="project-toggle" aria-expanded="false" aria-controls="pc-body-5">
          <div class="project-card-header">
            <div class="project-icon"><i class="fa-solid fa-prescription-bottle-medical"></i></div>
            <div class="project-toggle-right">
              <div class="project-links" onclick="event.stopPropagation()">
                <a href="https://github.com/DrUnkeN-SoUL" target="_blank" rel="noopener" aria-label="GitHub"><i class="fa-brands fa-github"></i></a>
              </div>
              <svg class="project-chevron" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/></svg>
            </div>
          </div>
          <div class="project-card-title-row">
            <span class="project-client">Personal Project</span>
            <h3 class="project-title">AI Medicine Bot (Durable)</h3>
            <div class="project-preview-tech">Python · AWS Bedrock · Lambda</div>
          </div>
        </button>
        <div class="project-card-collapsible" id="pc-body-5">
          <div class="project-card-body">
            <p class="project-desc">Serverless bot using AWS Lambda Durable Functions for tracking medicine lifecycles with state replay and zero external database. Amazon Bedrock Nova Lite parses physical prescriptions via multimodal text/image with free idempotency.</p>
          </div>
          <div class="project-card-footer">
            <span class="project-tag">Python 3.13</span><span class="project-tag">Durable Functions</span>
            <span class="project-tag">Bedrock Nova</span><span class="project-tag">Lambda</span>
            <span class="project-tag">Telegram API</span>
          </div>
        </div>
      </div>

      <div class="project-card glass-card" data-category="ai-automation">
        <button class="project-toggle" aria-expanded="false" aria-controls="pc-body-6">
          <div class="project-card-header">
            <div class="project-icon"><i class="fa-solid fa-face-smile"></i></div>
            <div class="project-toggle-right">
              <div class="project-links" onclick="event.stopPropagation()">
                <a href="https://github.com/DrUnkeN-SoUL" target="_blank" rel="noopener" aria-label="GitHub"><i class="fa-brands fa-github"></i></a>
              </div>
              <svg class="project-chevron" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/></svg>
            </div>
          </div>
          <div class="project-card-title-row">
            <span class="project-client">Academic / Personal</span>
            <h3 class="project-title">Facial Emotion CNN Detector</h3>
            <div class="project-preview-tech">Python · TensorFlow · OpenCV · Flask</div>
          </div>
        </button>
        <div class="project-card-collapsible" id="pc-body-6">
          <div class="project-card-body">
            <p class="project-desc">Deep learning facial emotion classifier trained on FER2013 — 7 emotional categories. OpenCV stream routing, TensorFlow models, and a Flask analytics interactive interface.</p>
          </div>
          <div class="project-card-footer">
            <span class="project-tag">Python</span><span class="project-tag">TensorFlow/Keras</span>
            <span class="project-tag">OpenCV</span><span class="project-tag">Flask</span>
            <span class="project-tag">NumPy</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* ─── Filter buttons ─── */
  .portfolio-filters {
    display: flex;
    gap: .35rem;
    margin-bottom: 3rem;
    flex-wrap: wrap;
  }

  @media (max-width: 480px) {
    .portfolio-filters { gap: .25rem; margin-bottom: 2rem; }
  }

  .filter-btn {
    font-family: 'JetBrains Mono', monospace;
    font-size: .6rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: .12em;
    color: var(--tx-3);
    background: transparent;
    border: 1px solid transparent;
    padding: .38rem .85rem;
    cursor: pointer;
    transition: all .22s var(--ease);
    min-height: 36px;
    display: inline-flex;
    align-items: center;
  }
  .filter-btn:hover  { color: var(--tx-2); border-color: var(--bd); }
  .filter-btn.active { color: var(--ac); border-color: var(--bd-ac); background: var(--ac-10); }

  @media (max-width: 480px) {
    .filter-btn { font-size: .56rem; padding: .35rem .65rem; }
  }

  /* ─── Grid layout ─── */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1px;
    background: var(--bd);
    border: 1px solid var(--bd);
    transition: opacity .18s var(--ease), transform .18s var(--ease);
  }

  @media (max-width: 768px) {
    .projects-grid {
      grid-template-columns: 1fr;
      align-items: start;
    }
  }

  .project-card {
    display: flex;
    flex-direction: column;
    background: var(--bg-1);
    border: none;
    transition: background .3s var(--ease), opacity .45s var(--ease), transform .45s var(--ease), filter .45s var(--ease);
  }

  .project-card::before, .project-card::after { display: none; }

  .project-card::before {
    content: '' !important;
    display: block !important;
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: var(--ac);
    opacity: 0;
    transition: opacity .35s var(--ease);
    z-index: 2;
  }

  .project-card:hover { background: var(--bg-2); transform: none; }
  .project-card:hover::before { opacity: 1; }

  /* ─── Toggle button (wraps header + title row) ─── */
  .project-toggle {
    display: flex;
    flex-direction: column;
    width: 100%;
    background: transparent;
    border: none;
    cursor: pointer;
    text-align: left;
    padding: 0;
    -webkit-tap-highlight-color: transparent;
    flex: 1;
  }

  .project-card-header {
    padding: 1.65rem 1.65rem .75rem;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }

  /* Right side of header on mobile: links + chevron stacked */
  .project-toggle-right {
    display: flex;
    align-items: center;
    gap: .75rem;
  }

  .project-chevron {
    width: 18px; height: 18px;
    color: var(--tx-3);
    transition: transform .3s var(--ease), color .2s var(--ease);
    flex-shrink: 0;
    display: none; /* hidden on desktop */
  }

  @media (max-width: 768px) {
    .project-chevron { display: block; }
  }

  .project-toggle[aria-expanded="true"] .project-chevron {
    transform: rotate(180deg);
    color: var(--ac);
  }

  .project-icon {
    width: 36px; height: 36px;
    display: flex; align-items: center; justify-content: center;
    font-size: .88rem;
    color: var(--ac-dim);
    border: 1px solid var(--bd);
    transition: border-color .3s, color .3s;
    flex-shrink: 0;
  }
  .project-card:hover .project-icon { border-color: var(--bd-ac); color: var(--ac); }

  .project-links {
    display: flex;
    gap: .75rem;
    color: var(--tx-2);
    font-size: .95rem;
  }
  .project-links a {
    min-width: 36px;
    min-height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .project-links a:hover { color: var(--ac); }

  /* Title row always visible inside the toggle */
  .project-card-title-row {
    padding: 0 1.65rem .85rem;
  }

  .project-client {
    font-family: 'JetBrains Mono', monospace;
    font-size: .56rem;
    text-transform: uppercase;
    letter-spacing: .18em;
    color: var(--tx-2);
    display: block;
    margin-bottom: .5rem;
  }

  .project-title {
    font-family: 'Cormorant Garant', serif;
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--tx-1);
    margin-bottom: 0;
    letter-spacing: -.01em;
    line-height: 1.2;
  }

  .project-preview-tech {
    display: none;
  }

  /* ─── Collapsible body ─── */
  .project-card-collapsible {
    overflow: hidden;
    /* Desktop: always expanded */
    max-height: 9999px;
    opacity: 1;
    transition: max-height .4s cubic-bezier(.4,0,.2,1), opacity .3s var(--ease);
  }

  @media (max-width: 768px) {
    .project-toggle {
      transition: background .2s var(--ease), transform .15s var(--ease);
    }
    .project-toggle:active {
      transform: scale(0.985);
    }
    .project-preview-tech {
      display: block;
      font-family: 'JetBrains Mono', monospace;
      font-size: .52rem;
      color: var(--tx-3);
      margin-top: .4rem;
      letter-spacing: .02em;
      transition: opacity .25s var(--ease), max-height .25s var(--ease), margin-top .25s var(--ease);
      opacity: 1;
      max-height: 20px;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .project-toggle[aria-expanded="true"] .project-preview-tech {
      opacity: 0;
      max-height: 0;
      margin-top: 0;
    }
    .project-card-collapsible {
      max-height: 0;
      opacity: 0;
    }
    .project-card-collapsible.open {
      max-height: 500px;
      opacity: 1;
    }
  }

  .project-card-body { padding: 0 1.65rem 1.1rem; flex: 1; }

  .project-desc {
    font-family: 'DM Sans', sans-serif;
    font-size: .85rem;
    color: var(--tx-2);
    line-height: 1.68;
    font-weight: 300;
  }

  .project-card-footer {
    padding: .85rem 1.65rem;
    border-top: 1px solid var(--bd);
    background: rgba(0,0,0,.2);
    display: flex;
    flex-wrap: wrap;
    gap: .3rem;
  }

  .project-tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: .56rem;
    color: #5c5a56;
    padding: .1rem .36rem;
    border: 1px solid rgba(255,255,255,.04);
    letter-spacing: .06em;
    text-transform: uppercase;
    transition: color .2s, border-color .2s;
    min-height: 24px;
    display: inline-flex;
    align-items: center;
  }
  .project-tag:hover { color: var(--ac); border-color: var(--bd-ac); }

  .project-card.inactive {
    opacity: 0.12;
    filter: grayscale(1) blur(0.4px);
    pointer-events: none;
    transform: scale(0.96);
  }
  .project-card.active {
    opacity: 1;
    filter: none;
    pointer-events: auto;
    transform: scale(1);
  }
</style>
