---
---

<section id="skills">
  <div class="container">
    <div class="section-rule-header reveal">
      <span class="section-rule-num">// 03 — Capabilities</span>
      <span class="section-rule-line"></span>
    </div>
    <div class="section-header reveal" style="margin-bottom:2rem">
      <div class="section-title-wrapper">
        <h2 class="section-title">Technical <em>Expertise</em></h2>
        <div class="section-title-line"></div>
      </div>
      <p class="section-subtitle">Proven competency map across frameworks, database engines, clouds, and core platforms.</p>
    </div>

    <div class="skills-grid">

      <div class="skills-category glass-card reveal">
        <button class="skills-toggle" aria-expanded="false" aria-controls="sk-body-1">
          <div class="skills-toggle-content">
            <h3 class="skills-category-title"><i class="fa-solid fa-server"></i> Backend</h3>
            <div class="skills-preview-text">Python · Go · Node.js · TypeScript</div>
          </div>
          <svg class="skills-chevron" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/></svg>
        </button>
        <div class="skill-list-wrap" id="sk-body-1">
          <div class="skill-list">
            <span class="skill-tag">Python — FastAPI / Flask / Django</span>
            <span class="skill-tag">Go — Gin / SQLX</span>
            <span class="skill-tag">Node.js</span>
            <span class="skill-tag">TypeScript</span>
            <span class="skill-tag">REST APIs</span>
            <span class="skill-tag">Microservices</span>
            <span class="skill-tag">WebSocket</span>
            <span class="skill-tag">APScheduler</span>
            <span class="skill-tag">Shell Scripting</span>
          </div>
        </div>
      </div>

      <div class="skills-category glass-card reveal reveal-d1">
        <button class="skills-toggle" aria-expanded="false" aria-controls="sk-body-2">
          <div class="skills-toggle-content">
            <h3 class="skills-category-title"><i class="fa-solid fa-cloud-arrow-up"></i> Cloud &amp; DevOps</h3>
            <div class="skills-preview-text">AWS · GCP · Docker · Terraform</div>
          </div>
          <svg class="skills-chevron" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/></svg>
        </button>
        <div class="skill-list-wrap" id="sk-body-2">
          <div class="skill-list">
            <span class="skill-tag">AWS — ECS · RDS · SQS · Lambda · Cognito</span>
            <span class="skill-tag">AWS — S3 · Athena · OpenSearch · ECR</span>
            <span class="skill-tag">AWS Lambda (Durable SDK)</span>
            <span class="skill-tag">GCP — BigQuery · GKE · IAM</span>
            <span class="skill-tag">Azure ARM / Multi-tenant App Reg</span>
            <span class="skill-tag">Docker &amp; Compose</span>
            <span class="skill-tag">Terraform &amp; Terragrunt</span>
            <span class="skill-tag">Kubernetes &amp; Helm</span>
            <span class="skill-tag">Ansible</span>
            <span class="skill-tag">GitHub Actions</span>
            <span class="skill-tag">Cloudflare Pages</span>
            <span class="skill-tag">Nginx</span>
          </div>
        </div>
      </div>

      <div class="skills-category glass-card reveal reveal-d2">
        <button class="skills-toggle" aria-expanded="false" aria-controls="sk-body-3">
          <div class="skills-toggle-content">
            <h3 class="skills-category-title"><i class="fa-solid fa-database"></i> Databases</h3>
            <div class="skills-preview-text">PostgreSQL · MySQL · Redis · SQLite</div>
          </div>
          <svg class="skills-chevron" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/></svg>
        </button>
        <div class="skill-list-wrap" id="sk-body-3">
          <div class="skill-list">
            <span class="skill-tag">PostgreSQL</span>
            <span class="skill-tag">MySQL / SQLAlchemy</span>
            <span class="skill-tag">OpenSearch</span>
            <span class="skill-tag">MongoDB</span>
            <span class="skill-tag">Redis</span>
            <span class="skill-tag">SQLite</span>
            <span class="skill-tag">Multi-tenant Schema Isolation</span>
            <span class="skill-tag">Row-Level Security</span>
          </div>
        </div>
      </div>

      <div class="skills-category glass-card reveal reveal-d3">
        <button class="skills-toggle" aria-expanded="false" aria-controls="sk-body-4">
          <div class="skills-toggle-content">
            <h3 class="skills-category-title"><i class="fa-solid fa-display"></i> Frontend &amp; Auth</h3>
            <div class="skills-preview-text">Next.js · React · Tailwind · OAuth2</div>
          </div>
          <svg class="skills-chevron" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/></svg>
        </button>
        <div class="skill-list-wrap" id="sk-body-4">
          <div class="skill-list">
            <span class="skill-tag">Next.js 14 / 15 / 16</span>
            <span class="skill-tag">React.js</span>
            <span class="skill-tag">Tailwind CSS / shadcn/ui</span>
            <span class="skill-tag">Radix UI</span>
            <span class="skill-tag">MUI (Material UI)</span>
            <span class="skill-tag">TanStack Table</span>
            <span class="skill-tag">React Flow</span>
            <span class="skill-tag">Framer Motion</span>
            <span class="skill-tag">OAuth2 / OIDC / JWT</span>
            <span class="skill-tag">AWS Cognito OAuth</span>
            <span class="skill-tag">Keycloak Identity</span>
            <span class="skill-tag">Secretless Architecture</span>
          </div>
        </div>
      </div>

      <div class="skills-category glass-card reveal reveal-d4 skills-span-2">
        <button class="skills-toggle" aria-expanded="false" aria-controls="sk-body-5">
          <div class="skills-toggle-content">
            <h3 class="skills-category-title"><i class="fa-solid fa-brain"></i> AI &amp; ML</h3>
            <div class="skills-preview-text">OpenAI · Bedrock · TensorFlow · OpenCV</div>
          </div>
          <svg class="skills-chevron" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/></svg>
        </button>
        <div class="skill-list-wrap" id="sk-body-5">
          <div class="skill-list">
            <span class="skill-tag">OpenAI SDK — GPT-4o</span>
            <span class="skill-tag">Amazon Bedrock — Nova Lite</span>
            <span class="skill-tag">TensorFlow / Keras</span>
            <span class="skill-tag">OpenCV Vision</span>
            <span class="skill-tag">LangChain (learning)</span>
            <span class="skill-tag">Stable Diffusion (learning)</span>
            <span class="skill-tag">Multimodal (text + image)</span>
            <span class="skill-tag">Structured JSON Output</span>
          </div>
        </div>
      </div>

      <div class="skills-category glass-card reveal skills-span-2">
        <button class="skills-toggle" aria-expanded="false" aria-controls="sk-body-6">
          <div class="skills-toggle-content">
            <h3 class="skills-category-title"><i class="fa-solid fa-lock"></i> Security &amp; Testing</h3>
            <div class="skills-preview-text">RBAC · Vitest · Playwright · Git</div>
          </div>
          <svg class="skills-chevron" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/></svg>
        </button>
        <div class="skill-list-wrap" id="sk-body-6">
          <div class="skill-list">
            <span class="skill-tag">Multi-tenant RBAC</span>
            <span class="skill-tag">Azure AD Admin Consent</span>
            <span class="skill-tag">reCAPTCHA v2</span>
            <span class="skill-tag">Soft-delete &amp; Audit Logging</span>
            <span class="skill-tag">Vitest Unit Testing</span>
            <span class="skill-tag">Playwright E2E</span>
            <span class="skill-tag">Web Vitals (LCP/CLS/FID)</span>
            <span class="skill-tag">Git &amp; Linux</span>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1px;
    background: var(--bd);
    border: 1px solid var(--bd);
  }

  @media (max-width: 768px) {
    .skills-grid {
      grid-template-columns: 1fr;
      align-items: start;
    }
  }

  @media (min-width: 769px) and (max-width: 900px) {
    .skills-grid { grid-template-columns: repeat(2, 1fr); }
  }

  /* Desktop Layout: Category card has original padding */
  .skills-category {
    background: var(--bg-1);
    transition: background .3s;
    overflow: hidden;
    padding: 1.75rem;
  }
  .skills-category:hover { background: var(--bg-2); }
  .skills-category::before { display: none; }

  /* Desktop: Toggle button is styled as a plain container */
  .skills-toggle {
    width: 100%;
    display: block;
    background: transparent;
    border: none;
    padding: 0;
    margin: 0;
    text-align: left;
    pointer-events: none;
    cursor: default;
    outline: none;
  }

  .skills-toggle-content {
    display: flex;
    flex-direction: column;
    width: 100%;
  }

  .skills-preview-text {
    display: none;
  }

  .skills-chevron {
    display: none !important;
  }

  .skills-category-title {
    display: flex;
    align-items: center;
    gap: .6rem;
    font-family: 'JetBrains Mono', monospace !important;
    font-size: .65rem !important;
    font-weight: 500 !important;
    text-transform: uppercase !important;
    letter-spacing: .14em !important;
    color: var(--tx-2) !important;
    margin-bottom: 1.2rem !important;
    padding-bottom: .85rem !important;
    border-bottom: 1px solid var(--bd) !important;
    line-height: 1 !important;
  }
  .skills-category-title i { color: var(--ac-dim); font-size: .75rem !important; }

  /* Desktop: Skill list wrap sits nicely below the header */
  .skill-list-wrap {
    padding: 0;
    margin: 0;
    border: none;
    max-height: none;
    opacity: 1;
    overflow: visible;
  }

  @media (max-width: 768px) {
    /* Mobile Layout: Remove card padding so toggle button & open panel stretch edge-to-edge */
    .skills-category {
      padding: 0;
    }

    /* Mobile Toggle Button: Full area tap target with chevron positioning */
    .skills-toggle {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1.5rem 1.75rem;
      cursor: pointer;
      pointer-events: auto;
      -webkit-tap-highlight-color: transparent;
      transition: background .2s var(--ease), transform .15s var(--ease);
    }
    .skills-toggle:active {
      transform: scale(0.985);
    }
    .skills-toggle[aria-expanded="true"] {
      background: var(--ac-10);
    }

    .skills-toggle-content {
      display: flex;
      flex-direction: column;
      flex-grow: 1;
      min-width: 0;
    }

    .skills-preview-text {
      display: block;
      font-family: 'JetBrains Mono', monospace;
      font-size: .52rem;
      color: var(--tx-3);
      margin-top: .45rem;
      letter-spacing: .02em;
      transition: opacity .25s var(--ease), max-height .25s var(--ease), margin-top .25s var(--ease);
      opacity: 1;
      max-height: 20px;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    
    .skills-toggle[aria-expanded="true"] .skills-preview-text {
      opacity: 0;
      max-height: 0;
      margin-top: 0;
    }

    .skills-chevron {
      display: block !important;
      width: 16px;
      height: 16px;
      color: var(--tx-3);
      flex-shrink: 0;
      transition: transform .3s var(--ease), color .2s var(--ease);
    }
    .skills-toggle[aria-expanded="true"] .skills-chevron {
      transform: rotate(180deg);
      color: var(--ac);
    }

    /* Mobile Category Title: No borders or margins inside the toggle */
    .skills-category-title {
      margin-bottom: 0 !important;
      padding-bottom: 0 !important;
      border-bottom: none !important;
    }

    /* Mobile Collapsible Panel */
    .skill-list-wrap {
      max-height: 0;
      opacity: 0;
      overflow: hidden;
      transition: max-height .4s cubic-bezier(.4,0,.2,1), opacity .3s var(--ease), padding .3s var(--ease);
      padding: 0 1.75rem;
      margin-top: 0;
      border-top: none;
    }
    .skill-list-wrap.open {
      max-height: 800px;
      opacity: 1;
      padding: 1rem 1.75rem 1.5rem;
      border-top: 1px solid var(--bd);
      margin-top: 0;
    }
  }



  .skill-list { display: flex; flex-wrap: wrap; gap: .35rem; }

  .skill-tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: .64rem;
    color: var(--tx-2);
    background: transparent;
    border: 1px solid var(--bd);
    padding: .28rem .55rem;
    letter-spacing: .04em;
    transition: color .2s, border-color .2s;
    cursor: default;
    min-height: 28px;
    display: inline-flex;
    align-items: center;
  }
  .skill-tag:hover { color: var(--ac); border-color: var(--bd-ac); }

  @media (min-width: 1025px) {
    .skills-grid { grid-template-columns: repeat(4, 1fr); }
    .skills-span-2 { grid-column: span 2; }
  }
</style>
